# Copy to .env.local and fill in. .env.local is gitignored — never commit it.
# In Vercel these go in Project Settings → Environment Variables.

# Supabase → Project Settings → API
# Safe to expose. Protected by row level security.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SECRET. Bypasses row level security entirely — anyone holding this can read
# every demo submission and every unpublished row.
#
# Server-side only. It must never gain a NEXT_PUBLIC_ prefix and must never be
# imported into a file that runs in the browser: the prefix is the only thing
# Next.js checks before inlining a value into the client bundle.
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare Turnstile — spam protection on the pitch form.
# Free at https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Resend — notification email when a demo arrives. https://resend.com
RESEND_API_KEY=
SUBMISSIONS_NOTIFY_EMAIL=

# Spotify Web API — pulls Mats' real discography onto the site.
# Create a free app at https://developer.spotify.com/dashboard
# (no redirect URI needed; this uses the Client Credentials flow).
# Server-only. Never prefix with NEXT_PUBLIC_.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
